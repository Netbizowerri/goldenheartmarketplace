# ============================================
# SERVER-SIDE ENVIRONMENT VARIABLES (.env)
# ============================================
# These are ONLY available on the server (Vercel, cPanel PHP)
# DO NOT expose secret keys to the browser

# Resend API Configuration
# ⚠️ Put your actual values in .env (which is gitignored), NOT in .env.example
# Copy this file to .env and fill in your real values
RESEND_API_KEY=re_replace_with_your_resend_api_key_here
ADMIN_EMAIL=goldenheartmarketplace@gmail.com
FROM_EMAIL=noreply@merchantsgoldenheart.com
SITE_NAME=Golden Heart Marketplace

# Privyr CRM Webhook (server-side only)
PRIVYR_WEBHOOK_URL=https://www.privyr.com/api/v1/incoming-leads/0vZfjMQw/JSh0Qptn

# ============================================
# CLIENT-SIDE ENVIRONMENT VARIABLES (.env.local)
# ============================================
# These are exposed to the browser with VITE_ or PUBLIC_ prefix
# Copy these values to .env.local (which is gitignored)

# VITE_COMPANY_NAME=Your Company Name
# VITE_FORM_ENDPOINT=/api/submit-lead.php
# VITE_COMPANY_EMAIL=support@example.com
# VITE_FACEBOOK_URL=https://facebook.com/yourpage
# VITE_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/...
# VITE_HERO_LOGO_URL=https://...
# VITE_DELIVERY_IMAGE_URL=https://...
# VITE_COMMUNITY_IMAGE_URL=https://...
# VITE_MERCHANT_COUNT_LABEL=Active Merchants
# VITE_MERCHANT_COUNT_VALUE=1,000+
# VITE_JOIN_COUNT_LABEL=Join 1,200+ businesses...
# VITE_REVENUE_GROWTH_STAT=+145%
