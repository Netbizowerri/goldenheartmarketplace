{
  "entities": {
    "MerchantLead": {
      "title": "Merchant Lead",
      "description": "Information collected from prospective vendors through the onboarding form.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Legal name of the merchant contact." },
        "businessName": { "type": "string", "description": "Registered business or brand name." },
        "email": { "type": "string", "format": "email", "description": "Contact email address." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "businessType": { "type": "string", "description": "Category of business (e.g. Fashion, Electronics)." },
        "country": { "type": "string", "description": "Country of operation." },
        "status": { "type": "string", "enum": ["new", "contacted", "converted"], "description": "Lead lifecycle status." },
        "source": { "type": "string", "description": "Where the lead came from (landing_page)." },
        "submittedAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission." }
      },
      "required": ["fullName", "businessName", "email", "phone", "businessType", "country", "status", "source", "submittedAt"]
    }
  },
  "firestore": {
    "merchant_leads/{leadId}": {
      "schema": "MerchantLead",
      "description": "Collection of all merchant applications."
    }
  }
}
